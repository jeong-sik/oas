opam-version: "2.0"
version: "0.122.0"
synopsis: "Anthropic Agent SDK for OCaml (Eio Edition)"
description:
  "A native OCaml implementation of the Anthropic Agent SDK using OCaml 5.x Eio for structured concurrency, inspired by Go SDK patterns."
maintainer: ["yousleepwhen@gmail.com"]
authors: ["Jeong-sik Yun"]
license: "MIT"
homepage: "https://github.com/jeong-sik/agent-sdk"
bug-reports: "https://github.com/jeong-sik/agent-sdk/issues"
depends: [
  "ocaml" {>= "5.1"}
  "dune" {>= "3.11" & >= "3.11"}
  "eio_main" {>= "0.12"}
  "cohttp-eio" {>= "6.0.0~alpha2"}
  "tls" {>= "0.17.0"}
  "tls-eio" {>= "0.17.0"}
  "ca-certs" {>= "0.2.3"}
  "yojson" {>= "2.1"}
  "ppx_deriving_yojson" {>= "3.7"}
  "ppx_deriving" {>= "5.2.1"}
  "uri" {>= "4.4"}
  "mcp_protocol" {>= "1.3.0"}
  "cmdliner" {>= "1.3.0"}
  "alcotest" {with-test & >= "1.7"}
